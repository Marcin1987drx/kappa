{
  "name": "kappaplannung",
  "version": "1.0.0",
  "description": "DRÄXLMAIER Kappa Planning Application",
  "main": "electron-main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "build:portable": "bash build-portable.sh",
    "build:electron": "bash build-electron.sh"
  },
  "build": {
    "appId": "com.draxlmaier.kappaplannung",
    "productName": "Kappa Plannung",
    "icon": "build/icon.ico",
    "files": [
      "electron-main.cjs",
      "electron-preload.cjs"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "backend/dist/server.bundle.cjs",
        "to": "backend/dist/server.bundle.cjs"
      },
      {
        "from": "backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "backend/node_modules/sql.js",
        "to": "backend/node_modules/sql.js"
      },
      {
        "from": "backend/data",
        "to": "backend/data"
      },
      {
        "from": "splash.html",
        "to": "splash.html"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "directories": {
      "output": "release"
    },
    "portable": {
      "artifactName": "KappaPlanning.exe"
    }
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.0",
    "jspdf": "^4.1.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.10.6",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
